{
    "name": "polysource/widgets",
    "description": "Polysource — composable dashboard widgets: counters, top-N lists, sparklines.",
    "type": "symfony-bundle",
    "license": "MIT",
    "keywords": [
        "polysource",
        "widgets",
        "dashboard",
        "kpi",
        "symfony"
    ],
    "homepage": "https://github.com/polysource/polysource",
    "support": {
        "issues": "https://github.com/polysource/polysource/issues",
        "source": "https://github.com/polysource/polysource"
    },
    "require": {
        "php": ">=8.1",
        "polysource/core": "0.1.x-dev",
        "symfony/config": "^5.4 || ^6.0 || ^7.0 || ^8.0",
        "symfony/dependency-injection": "^5.4 || ^6.0 || ^7.0 || ^8.0",
        "symfony/http-kernel": "^5.4 || ^6.0 || ^7.0 || ^8.0",
        "symfony/translation": "^5.4 || ^6.0 || ^7.0 || ^8.0",
        "symfony/yaml": "^5.4 || ^6.0 || ^7.0 || ^8.0",
        "twig/twig": "^3.0"
    },
    "require-dev": {
        "phpunit/phpunit": "^10.5 || ^11.5"
    },
    "autoload": {
        "psr-4": {
            "Polysource\\Widgets\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Polysource\\Widgets\\Tests\\": "tests/"
        }
    },
    "config": {
        "sort-packages": true
    },
    "extra": {
        "branch-alias": {
            "dev-main": "0.1.x-dev"
        }
    }
}
